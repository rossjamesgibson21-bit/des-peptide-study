{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "des-pep-cesd-001/identifier_scheme",
  "title": "DES-PEP-CESD-001 identifier scheme",
  "type": "object",
  "required": ["protocol_id", "scheme_version", "frozen_at_gate", "peptides",
               "caps", "solvents", "masked_arms", "start_blocks",
               "model_versions", "id_templates", "seed_policy"],
  "additionalProperties": true,
  "properties": {
    "protocol_id": {"const": "DES-PEP-CESD-001"},
    "scheme_version": {"type": "number"},
    "frozen_at_gate": {"const": 0},
    "peptides": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "code", "role"],
        "properties": {
          "id": {"type": "string", "pattern": "^PEP-"},
          "code": {"type": "string", "enum": ["GGE", "CME", "YIY"]},
          "role": {"type": "string", "minLength": 1}
        }
      }
    },
    "caps": {
      "type": "object",
      "required": ["n_terminus", "c_terminus"],
      "properties": {
        "n_terminus": {"type": "string", "minLength": 1},
        "c_terminus": {"type": "string", "minLength": 1}
      }
    },
    "solvents": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "code", "description"],
        "properties": {
          "id": {"type": "string", "pattern": "^SOL-"},
          "code": {"type": "string", "enum": ["WATER", "RELINE", "GLYCELINE"]}
        }
      }
    },
    "masked_arms": {
      "type": "object",
      "required": ["namespace", "key_owner_role", "key_location", "mapping_status"],
      "properties": {
        "namespace": {"type": "array", "minItems": 3, "maxItems": 3,
                      "items": {"type": "string", "pattern": "^ARM-"}},
        "key_owner_role": {"type": "string", "minLength": 1},
        "mapping_status": {"type": "string",
          "description": "Must NOT contain a resolved arm->solvent mapping (hard firewall §18.3)",
          "pattern": "^TO BE ASSIGNED"}
      }
    },
    "start_blocks": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "code"],
        "properties": {
          "id": {"type": "string", "pattern": "^SB-"},
          "code": {"type": "string", "enum": ["compact", "intermediate", "extended"]}
        }
      }
    },
    "model_versions": {
      "type": "object",
      "required": ["versions", "version_bump_rule"],
      "properties": {
        "versions": {"type": "array", "minItems": 1,
          "items": {"type": "object", "required": ["id", "status"],
                    "properties": {"id": {"type": "string", "pattern": "^MODEL-v"}}}}
      }
    },
    "id_templates": {
      "type": "object",
      "required": ["preparation", "replica", "run", "trajectory", "dft_cluster"]
    },
    "seed_policy": {
      "type": "object",
      "required": ["reserved_at", "recorded_in"]
    }
  }
}
